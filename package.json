{
  "name": "act-diagnosis-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 67",
    "test": "vitest run",
    "verify:coaching:ci": "node scripts/verify-coaching-ci.mjs",
    "verify:coaching:production": "npm run smoke:coaching && npm run test:coaching-quality:3x && npm run test:coaching-image-latency && npm run test:coaching-browser",
    "smoke:coaching": "node scripts/smoke-coaching-chat.mjs",
    "test:coaching-quality": "node scripts/evaluate-coaching-quality.mjs",
    "test:coaching-quality:3x": "npm run test:coaching-quality && npm run test:coaching-quality && npm run test:coaching-quality",
    "test:coaching-image-latency": "node scripts/probe-coaching-image-latency.mjs",
    "test:coaching-browser": "node scripts/e2e-coaching-browser.mjs",
    "test:coaching-all": "npm run verify:coaching:ci && npm run verify:coaching:production"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.110.7",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "next": "^15.5.18",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.17.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.18",
    "playwright": "^1.61.1",
    "vercel": "^50.37.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
